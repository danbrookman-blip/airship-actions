# airship-actions environment
#
# Copy to `.env.local` and fill in to read LIVE Airship data through the
# built-in dev/preview proxy (see airship-proxy.ts). With none of these set the
# app runs on bundled sample data — no configuration required.

# --- Server-side only (NEVER exposed to the browser) ---
# Your Airship API token. Used by the /api/airship proxy to authenticate
# upstream requests. Because it is NOT prefixed with VITE_, Vite never ships it
# to the client bundle.
AIRSHIP_API_TOKEN=

# Optional: override the upstream Airship API base URL.
AIRSHIP_API_BASE_URL=https://api.airship.co.uk/v1

# --- Client flag (safe to expose) ---
# Set to "true" to make the app read live data via the proxy instead of the
# bundled sample data. Leave unset/false for the zero-config sample experience.
VITE_AIRSHIP_LIVE=false
